# ==========================================
# GearShift Backend Environment Configuration
# ==========================================
# Copy this file to .env and adjust values for your local environment.
# DO NOT commit sensitive secrets to version control.

# Application Server
PORT=5000
NODE_ENV=development

# MongoDB Connection String
# For local development: mongodb://127.0.0.1:27017/gearshift_dev
# For MongoDB Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/gearshift_prod
MONGODB_URI=mongodb://127.0.0.1:27017/gearshift_dev

# Authentication & Security (JWT)
# Generate a strong secret string in production (e.g., using `openssl rand -hex 32`)
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=1d

# Cross-Origin Resource Sharing (CORS)
# Restrict to your frontend origin in production (e.g., http://localhost:3000)
CORS_ORIGIN=*

# Logging Configuration
# Levels: error | warn | info | http | debug
LOG_LEVEL=info
